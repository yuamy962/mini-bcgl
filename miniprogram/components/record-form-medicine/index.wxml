<view class="form-card">
  <view class="form-cell">
    <text class="form-cell-label">药物名称 <text class="required">*</text></text>
    <input class="form-cell-input" placeholder="请输入药物名称" placeholder-class="placeholder" value="{{form.drug}}" bindinput="onDrugInput" />
  </view>

  <picker mode="date" bindchange="onStartDateChange" value="{{form.startDate}}" end="{{today}}">
    <view class="form-cell form-cell-arrow">
      <text class="form-cell-label">开始时间 <text class="required">*</text></text>
      <text class="form-cell-value {{form.startDate ? '' : 'placeholder'}}">{{form.startDate || '请选择日期'}}</text>
    </view>
  </picker>

  <picker mode="date" bindchange="onNextDateChange" value="{{form.nextDate}}">
    <view class="form-cell form-cell-arrow">
      <text class="form-cell-label">下次拿药时间</text>
      <text class="form-cell-value {{form.nextDate ? '' : 'placeholder'}}">{{form.nextDate || '请选择日期'}}</text>
    </view>
  </picker>
</view>

<button class="btn-primary" bindtap="onSubmit">保存</button>
