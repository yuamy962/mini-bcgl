<view class="timeline-card type-{{item.type}}" bindtap="onTap">
  <view class="card-icon">{{item.icon || '📝'}}</view>
  <view class="card-content">
    <view class="card-title">{{item.title}}</view>
    <view class="card-meta">
      <text class="meta-type type-{{item.type}}">{{item.typeName || item.type}}</text>
      <text class="meta-date" wx:if="{{item.date}}">{{item.date}}</text>
    </view>
    <view class="card-extra" wx:if="{{item.value}}">
      <text class="extra-value">{{item.value}}</text>
      <text class="extra-unit" wx:if="{{item.unit}}">{{item.unit}}</text>
    </view>
    <view class="card-extra" wx:if="{{item.hospital}}">
      <text class="extra-text">{{item.hospital}}</text>
    </view>
    <view class="card-extra" wx:if="{{item.doctorAdvice}}">
      <text class="extra-text">医生建议：{{item.doctorAdvice}}</text>
    </view>
    <view class="card-extra" wx:if="{{item.remark || item.content}}">
      <text class="extra-text">{{item.remark || item.content}}</text>
    </view>
  </view>
</view>
