.timeline-card {
  display: flex;
  align-items: flex-start;
  background: var(--white);
  border-radius: var(--radius);
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
}

/* 左侧类型色条 */
.timeline-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 0 4rpx 4rpx 0;
  background: var(--type-note);
}

.timeline-card.type-psa::before { background: var(--type-psa); }
.timeline-card.type-check::before { background: var(--type-check); }
.timeline-card.type-injection::before { background: var(--type-injection); }
.timeline-card.type-medicine::before { background: var(--type-medicine); }
.timeline-card.type-visit::before { background: var(--type-visit); }
.timeline-card.type-note::before { background: var(--type-note); }

.card-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  background: var(--primary-light);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
  word-break: break-all;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.meta-type {
  font-size: 22rpx;
  font-weight: 500;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  background: var(--primary-light);
  color: var(--primary);
}

.meta-type.type-psa { background: var(--primary-light); color: var(--type-psa); }
.meta-type.type-check { background: #F3E5F5; color: var(--type-check); }
.meta-type.type-injection { background: var(--success-bg); color: var(--type-injection); }
.meta-type.type-medicine { background: var(--warning-bg); color: var(--type-medicine); }
.meta-type.type-visit { background: #E0F7FA; color: var(--type-visit); }
.meta-type.type-note { background: var(--bg); color: var(--type-note); }

.meta-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.card-extra {
  margin-top: 4rpx;
}

.extra-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
}

.extra-unit {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-left: 6rpx;
}

.extra-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}
