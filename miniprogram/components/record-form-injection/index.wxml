<view class="form-card">
  <picker bindchange="onDrugChange" value="{{drugOptions.indexOf(form.drug)}}" range="{{drugOptions}}">
    <view class="form-cell form-cell-arrow">
      <text class="form-cell-label">药物名称 <text class="required">*</text></text>
      <text class="form-cell-value">{{form.drug}}</text>
    </view>
  </picker>

  <picker mode="date" bindchange="onDateChange" value="{{form.date}}" end="{{today}}">
    <view class="form-cell form-cell-arrow">
      <text class="form-cell-label">注射日期 <text class="required">*</text></text>
      <text class="form-cell-value {{form.date ? '' : 'placeholder'}}">{{form.date || '请选择日期'}}</text>
    </view>
  </picker>

  <picker bindchange="onCycleChange" value="{{cycleIndex}}" range="{{cycleOptions}}" range-key="label">
    <view class="form-cell form-cell-arrow">
      <text class="form-cell-label">注射周期 <text class="required">*</text></text>
      <text class="form-cell-value">{{cycleOptions[cycleIndex].label}}</text>
    </view>
  </picker>

  <view class="form-cell">
    <text class="form-cell-label">下次注射日期</text>
    <text class="form-cell-value" style="color: var(--primary); font-weight: 500;">{{form.nextDate}}</text>
  </view>

  <view class="form-cell">
    <text class="form-cell-label">医院</text>
    <input class="form-cell-input" placeholder="可选填" placeholder-class="placeholder" value="{{form.hospital}}" bindinput="onHospitalInput" />
  </view>
</view>

<button class="btn-primary" bindtap="onSubmit">保存</button>
