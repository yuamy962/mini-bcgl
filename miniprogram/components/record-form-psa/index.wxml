<view class="form-card">
  <picker bindchange="onTypeChange" value="{{indicatorOptions.indexOf(form.indicatorType)}}" range="{{indicatorOptions}}">
    <view class="form-cell form-cell-arrow">
      <text class="form-cell-label">指标类型 <text class="required">*</text></text>
      <text class="form-cell-value">{{form.indicatorType}}</text>
    </view>
  </picker>

  <view class="form-cell">
    <text class="form-cell-label">数值 <text class="required">*</text></text>
    <input class="form-cell-input" type="digit" placeholder="请输入数值" placeholder-class="placeholder" value="{{form.value}}" bindinput="onValueInput" />
  </view>

  <picker mode="date" bindchange="onDateChange" value="{{form.date}}" end="{{today}}">
    <view class="form-cell form-cell-arrow">
      <text class="form-cell-label">日期 <text class="required">*</text></text>
      <text class="form-cell-value {{form.date ? '' : 'placeholder'}}">{{form.date || '请选择日期'}}</text>
    </view>
  </picker>

  <view class="form-cell">
    <text class="form-cell-label">医院</text>
    <input class="form-cell-input" placeholder="可选填" placeholder-class="placeholder" value="{{form.hospital}}" bindinput="onHospitalInput" />
  </view>

  <view class="recent-hospitals" wx:if="{{recentHospitals.length > 0}}">
    <text class="recent-label">最近：</text>
    <view class="recent-tag" wx:for="{{recentHospitals}}" wx:key="*this" bindtap="onSelectRecentHospital" data-name="{{item}}">{{item}}</view>
  </view>
</view>

<button class="btn-primary" bindtap="onSubmit">保存</button>
