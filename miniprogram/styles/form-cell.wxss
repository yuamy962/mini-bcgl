/* === 表单卡片（iOS 设置页风格）=== */
.form-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.form-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
  border-bottom: 1rpx solid var(--border);
  box-sizing: border-box;
}

.form-cell:last-child {
  border-bottom: none;
}

.form-cell-label {
  font-size: 30rpx;
  color: var(--text-main);
  flex-shrink: 0;
  margin-right: 24rpx;
  font-weight: 400;
}

.form-cell-label .required {
  color: var(--danger);
  margin-left: 4rpx;
}

.form-cell-value {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-main);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-cell-value.placeholder {
  color: var(--text-tertiary);
}

.form-cell-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-main);
  background: transparent;
  border: none;
  height: 48rpx;
  line-height: 48rpx;
}

.form-cell-input.placeholder {
  color: var(--text-tertiary);
}

.form-cell-arrow {
  padding-right: 24rpx;
  position: relative;
}

.form-cell-arrow::after {
  content: '';
  position: absolute;
  right: 32rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #C7C7CC;
  border-right: 3rpx solid #C7C7CC;
  transform: translateY(-50%) rotate(45deg);
}

.form-cell-arrow .form-cell-value {
  padding-right: 24rpx;
}

.form-cell-textarea {
  display: block;
  padding: 28rpx 32rpx;
}

.form-cell-textarea .form-cell-label {
  display: block;
  margin-bottom: 16rpx;
}

.form-cell-textarea textarea {
  width: 100%;
  min-height: 140rpx;
  font-size: 30rpx;
  color: var(--text-main);
  background: transparent;
  line-height: 1.5;
}
