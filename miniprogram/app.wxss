/**app.wxss - Design System V1**/
page {
  /* === 色彩系统 === */
  --primary: #4A7CFF;
  --primary-light: #EDF1FF;
  --primary-bg: #F0F5FF;
  --primary-shadow: rgba(74, 124, 255, 0.25);

  --success: #4CAF50;
  --success-bg: #E8F5E9;
  --success-light: #4CAF5020;

  --warning: #FF9800;
  --warning-bg: #FFF3E0;
  --warning-light: #FF980020;

  --danger: #FF6B6B;
  --danger-bg: #FFEBEE;
  --danger-light: #FF6B6B20;

  /* 类型色（时间轴） */
  --type-psa: #4A7CFF;
  --type-injection: #4CAF50;
  --type-check: #9C27B0;
  --type-medicine: #FF9800;
  --type-visit: #00BCD4;
  --type-note: #999999;

  /* 中性色 */
  --text-main: #222222;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border: #EAECEF;
  --bg: #F7F8FA;
  --white: #FFFFFF;
  --timeline-line: #D8DCE3;

  /* === 圆角系统 === */
  --radius: 20rpx;
  --radius-btn: 28rpx;
  --radius-pill: 999rpx;

  /* === 阴影系统 === */
  --shadow-card: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  --shadow-float: 0 6rpx 16rpx rgba(74, 124, 255, 0.25);
  --shadow-timeline-node: 0 2rpx 6rpx rgba(74, 124, 255, 0.2);

  background: var(--bg);
  color: var(--text-main);
  font-size: 30rpx;
  line-height: 1.5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* === 容器 === */
.container {
  padding: 32rpx;
  box-sizing: border-box;
}

/* === 卡片 === */
.card {
  background: var(--white);
  border-radius: var(--radius);
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
}

/* === 按钮 === */
.btn-primary {
  background: var(--primary);
  color: var(--white);
  border-radius: var(--radius-btn);
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  margin-top: 40rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

/* === 区块标题 === */
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
}

/* === 表单 === */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-label .required {
  color: var(--danger);
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 84rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--text-main);
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: var(--primary);
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--text-main);
  border: 2rpx solid transparent;
}

.picker-value {
  width: 100%;
  height: 84rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--text-main);
  line-height: 84rpx;
}

.picker-value.placeholder {
  color: var(--text-tertiary);
}

/* === 安全区 === */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* === 浮动添加按钮 === */
.float-add-btn {
  position: fixed;
  bottom: 80rpx;
  right: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: var(--primary);
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-float);
  z-index: 100;
}

.add-icon {
  color: var(--white);
  font-size: 52rpx;
  font-weight: 300;
  line-height: 96rpx;
}

/* === 状态标签 === */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.tag-primary { color: var(--primary); background: var(--primary-light); }
.tag-success { color: var(--success); background: var(--success-bg); }
.tag-warning { color: var(--warning); background: var(--warning-bg); }
.tag-danger { color: var(--danger); background: var(--danger-bg); }

/* === 表单卡片（iOS 设置页风格） === */
.form-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.form-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
  border-bottom: 1rpx solid var(--border);
  box-sizing: border-box;
}

.form-cell:last-child {
  border-bottom: none;
}

.form-cell-label {
  font-size: 30rpx;
  color: var(--text-main);
  flex-shrink: 0;
  margin-right: 24rpx;
  font-weight: 400;
}

.form-cell-label .required {
  color: var(--danger);
  margin-left: 4rpx;
}

.form-cell-value {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-main);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-cell-value.placeholder {
  color: var(--text-tertiary);
}

.form-cell-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-main);
  background: transparent;
  border: none;
  height: 48rpx;
  line-height: 48rpx;
}

.form-cell-input.placeholder,
.form-cell textarea.placeholder {
  color: var(--text-tertiary);
}

.form-cell-arrow {
  padding-right: 24rpx;
  position: relative;
}

.form-cell-arrow::after {
  content: '';
  position: absolute;
  right: 32rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #C7C7CC;
  border-right: 3rpx solid #C7C7CC;
  transform: translateY(-50%) rotate(45deg);
}

.form-cell-arrow .form-cell-value {
  padding-right: 24rpx;
}

.form-cell-textarea {
  display: block;
  padding: 28rpx 32rpx;
}

.form-cell-textarea .form-cell-label {
  display: block;
  margin-bottom: 16rpx;
}

.form-cell-textarea textarea {
  width: 100%;
  min-height: 140rpx;
  font-size: 30rpx;
  color: var(--text-main);
  background: transparent;
  line-height: 1.5;
}

/* === 信息层级辅助 === */
.text-main { color: var(--text-main); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
