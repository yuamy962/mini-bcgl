.detail-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.detail-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.detail-type {
  font-size: 26rpx;
  color: var(--primary);
  background: var(--primary-bg);
  padding: 4rpx 20rpx;
  border-radius: 8rpx;
}

.detail-card {
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  margin-right: 30rpx;
}

.detail-value {
  font-size: 28rpx;
  color: var(--text-main);
  text-align: right;
  word-break: break-all;
  flex: 1;
}

.image-card {
  margin-bottom: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.detail-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  background: var(--bg);
}

.detail-footer {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.create-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.btn-delete {
  background: var(--danger-bg);
  color: var(--danger);
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  margin-top: 20rpx;
}

.btn-delete::after {
  border: none;
}
