.timeline-container {
  padding-bottom: 140rpx;
}

.timeline-list {
  padding: 0 32rpx;
}

.float-add-btn {
  position: fixed;
  bottom: 80rpx;
  right: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: var(--primary);
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-float);
  z-index: 100;
}

.add-icon {
  color: var(--white);
  font-size: 52rpx;
  font-weight: 300;
  line-height: 96rpx;
}
