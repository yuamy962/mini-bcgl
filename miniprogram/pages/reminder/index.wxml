<view class="container reminder-container">
  <!-- 列表 -->
  <view class="reminder-list" wx:if="{{!loading && reminders.length > 0}}">
    <view class="reminder-card {{item.isActive ? '' : 'inactive'}}" wx:for="{{reminders}}" wx:key="_id">
      <view class="reminder-main" bindtap="onEdit" data-id="{{item._id}}">
        <view class="reminder-header">
          <text class="reminder-title">{{item.title}}</text>
          <text class="reminder-type-tag">{{item.type === 'check' ? '复查' : item.type === 'medicine' ? '用药' : '打针'}}</text>
        </view>
        <view class="reminder-body">
          <text class="reminder-date">下次：{{item.nextDate}}</text>
          <text class="reminder-cycle" wx:if="{{item.cycleDays}}">每{{item.cycleDays}}天</text>
        </view>
      </view>
      <view class="reminder-actions">
        <switch checked="{{item.isActive}}" bindchange="onToggle" data-id="{{item._id}}" color="#2B6AFF" />
        <text class="action-delete" bindtap="onDelete" data-id="{{item._id}}">删除</text>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{!loading && reminders.length === 0}}" title="暂无提醒" description="添加复查、用药、打针提醒，不再遗漏治疗" btnText="添加提醒" bind:btnTap="onAdd" />
  <loading-state wx:if="{{loading}}" />

  <!-- 添加/编辑表单弹层 -->
  <view class="form-overlay" wx:if="{{showForm}}" bindtap="onCancel">
    <view class="form-panel" catchtap="preventClose">
      <view class="form-head">
        <text class="form-title">{{editingId ? '编辑提醒' : '添加提醒'}}</text>
        <text class="form-close" bindtap="onCancel">✕</text>
      </view>

      <view class="form-body">
        <view class="form-group">
          <text class="form-label">提醒类型</text>
          <picker bindchange="onTypeChange" value="{{typeIndex}}" range="{{typeOptions}}" range-key="label">
            <view class="picker-value">{{typeOptions[typeIndex].label}}</view>
          </picker>
        </view>

        <view class="form-group">
          <text class="form-label">提醒标题 <text class="required">*</text></text>
          <input class="form-input" placeholder="例如：PSA复查、拿药提醒" value="{{form.title}}" bindinput="onTitleInput" />
        </view>

        <view class="form-group">
          <text class="form-label">下次提醒日期 <text class="required">*</text></text>
          <picker mode="date" bindchange="onDateChange" value="{{form.nextDate}}">
            <view class="picker-value">{{form.nextDate || '请选择日期'}}</view>
          </picker>
        </view>

        <view class="form-group">
          <text class="form-label">周期天数（可选填）</text>
          <input class="form-input" type="number" placeholder="例如：28，不填则为一次性提醒" value="{{form.cycleDays}}" bindinput="onCycleInput" />
        </view>

        <button class="btn-primary" bindtap="onSubmit">保存</button>
      </view>
    </view>
  </view>
</view>

<!-- 添加按钮 -->
<view class="float-add-btn" bindtap="onAdd">
  <text class="add-icon">+</text>
</view>
