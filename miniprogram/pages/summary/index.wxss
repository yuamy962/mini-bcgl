.summary-container {
  padding-bottom: 40rpx;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 750px;
  height: 2000px;
}

.summary-content {
  padding: 0 30rpx;
}

.summary-header {
  text-align: center;
  padding: 30rpx 0;
}

.summary-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.summary-meta {
  display: flex;
  flex-direction: column;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.section-block {
  background: var(--white);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.block-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border);
}

.block-list {
  padding: 4rpx 0;
}

.block-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.item-date {
  font-size: 26rpx;
  color: var(--text-tertiary);
  width: 200rpx;
  flex-shrink: 0;
}

.item-value {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
}

.item-text {
  font-size: 28rpx;
  color: var(--text-main);
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.block-empty {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 16rpx 0;
  text-align: center;
}

.disclaimer {
  text-align: center;
  padding: 20rpx 0 40rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.summary-actions {
  padding: 0 30rpx;
}

.btn-share {
  background: var(--primary-bg);
  color: var(--primary);
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  margin-top: 20rpx;
}

.btn-share::after {
  border: none;
}
