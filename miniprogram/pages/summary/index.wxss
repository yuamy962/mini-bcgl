.summary-container {
  padding-bottom: 40rpx;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 750px;
  height: 2000px;
}

.summary-content {
  padding: 0 32rpx;
}

.summary-header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.summary-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.summary-meta {
  display: flex;
  flex-direction: column;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.section-block {
  background: var(--white);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.block-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.block-list {
  padding: 4rpx 0;
}

.block-item {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
}

.item-date {
  font-size: 26rpx;
  color: var(--text-tertiary);
  width: 200rpx;
  flex-shrink: 0;
}

.item-value {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
}

.item-text {
  font-size: 28rpx;
  color: var(--text-main);
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.block-empty {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 20rpx 0;
  text-align: center;
}

.narrative-block {
  background: linear-gradient(135deg, var(--white) 0%, #FAFBFF 100%);
}

.narrative-list {
  padding: 8rpx 0;
}

.narrative-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.narrative-dot {
  width: 10rpx;
  height: 10rpx;
  background: var(--primary);
  border-radius: 50%;
  margin-right: 18rpx;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.narrative-dot.down {
  background: var(--success);
}

.narrative-dot.up {
  background: var(--danger);
}

.narrative-dot.green {
  background: var(--success);
}

.narrative-dot.purple {
  background: #9C27B0;
}

.narrative-dot.cyan {
  background: #00BCD4;
}

.narrative-text {
  font-size: 30rpx;
  color: var(--text-main);
  line-height: 1.5;
  flex: 1;
}

.disclaimer {
  text-align: center;
  padding: 24rpx 0 40rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.summary-actions {
  padding: 0 32rpx;
}

.btn-share {
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-btn);
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  margin-top: 20rpx;
  font-weight: 500;
}

.btn-share::after {
  border: none;
}
