.summary-container {
  padding-bottom: 40rpx;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 750px;
  height: 2000px;
}

.summary-content {
  padding: 0 32rpx;
}

/* === 顶部品牌色标题区 === */
.summary-hero {
  background: var(--primary);
  margin: 0 -32rpx;
  padding: 48rpx 32rpx 80rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.summary-hero::before {
  content: '';
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  right: -80rpx;
  top: -100rpx;
}

.summary-hero::after {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  left: -60rpx;
  bottom: -60rpx;
}

.summary-hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  position: relative;
  z-index: 1;
}

.summary-hero-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
}

/* === 患者信息卡片 === */
.patient-card {
  background: var(--white);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.patient-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--primary-light);
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  margin-right: 24rpx;
}

.patient-info {
  flex: 1;
}

.patient-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.patient-date {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* === 通用区块卡片 === */
.section-block {
  background: var(--white);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.block-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.block-header-bar {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.block-header-bar.primary { background: var(--primary); }
.block-header-bar.success { background: var(--success); }
.block-header-bar.purple { background: #9C27B0; }
.block-header-bar.cyan { background: #00BCD4; }
.block-header-bar.warning { background: var(--warning); }

.block-header-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.block-list {
  padding: 4rpx 0;
}

.block-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.block-item:last-child {
  border-bottom: none;
}

.item-date {
  font-size: 26rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
  margin-right: 24rpx;
}

.item-value {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
}

.item-value.up {
  color: var(--danger);
}

.item-text {
  font-size: 28rpx;
  color: var(--text-main);
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.block-empty {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 20rpx 0;
  text-align: center;
}

/* === 病情变化叙述区块 === */
.narrative-block {
  background: linear-gradient(135deg, var(--white) 0%, #FAFBFF 100%);
}

.narrative-list {
  padding: 8rpx 0;
}

.narrative-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.narrative-dot {
  width: 10rpx;
  height: 10rpx;
  background: var(--primary);
  border-radius: 50%;
  margin-right: 18rpx;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.narrative-dot.down { background: var(--success); }
.narrative-dot.up { background: var(--danger); }
.narrative-dot.green { background: var(--success); }
.narrative-dot.purple { background: #9C27B0; }
.narrative-dot.cyan { background: #00BCD4; }

.narrative-text {
  font-size: 30rpx;
  color: var(--text-main);
  line-height: 1.5;
  flex: 1;
}

/* === 提醒卡片（特殊样式） === */
.reminder-block {
  background: linear-gradient(135deg, #FFF7ED 0%, #FFFBF5 100%);
  border: 1rpx solid rgba(255, 152, 0, 0.15);
}

.reminder-block .block-item {
  border-bottom-color: rgba(255, 152, 0, 0.15);
}

.reminder-block .item-text {
  color: #E65100;
  font-weight: 500;
}

/* === 底部免责声明 === */
.disclaimer {
  background: #F0F0F0;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  text-align: center;
  margin: 32rpx 0;
}

.disclaimer-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
}

/* === 操作按钮 === */
.summary-actions {
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.btn-share {
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-btn);
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  margin-top: 20rpx;
  font-weight: 500;
}

.btn-share::after {
  border: none;
}
