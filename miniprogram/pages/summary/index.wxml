<view class="container summary-container">
  <loading-state wx:if="{{loading}}" />

  <block wx:if="{{!loading && summaryData}}">
    <!-- 隐藏画布用于生成图片 -->
    <canvas canvas-id="summaryCanvas" class="hidden-canvas"></canvas>

    <view class="summary-content">
      <!-- 标题区 -->
      <view class="summary-header">
        <view class="summary-title">病程摘要</view>
        <view class="summary-meta">
          <text>患者：{{summaryData.patientInfo.name || ''}}</text>
          <text>生成于 {{summaryData.generatedAt}}</text>
        </view>
      </view>

      <!-- 指标变化 -->
      <view class="section-block">
        <view class="block-title">指标变化（TPSA）</view>
        <view class="block-list">
          <view class="block-item" wx:for="{{summaryData.psaList}}" wx:key="_id">
            <text class="item-date">{{item.date}}</text>
            <text class="item-value">{{item.value}} ng/mL</text>
          </view>
          <view class="block-empty" wx:if="{{summaryData.psaList.length === 0}}">暂无记录</view>
        </view>
      </view>

      <!-- 治疗记录 -->
      <view class="section-block">
        <view class="block-title">治疗记录</view>
        <view class="block-list">
          <view class="block-item" wx:for="{{summaryData.treatments}}" wx:key="_id">
            <text class="item-date">{{item.date}}</text>
            <text class="item-text">{{item.title}}</text>
          </view>
          <view class="block-empty" wx:if="{{summaryData.treatments.length === 0}}">暂无记录</view>
        </view>
      </view>

      <!-- 检查记录 -->
      <view class="section-block">
        <view class="block-title">检查记录</view>
        <view class="block-list">
          <view class="block-item" wx:for="{{summaryData.checks}}" wx:key="_id">
            <text class="item-date">{{item.date}}</text>
            <text class="item-text">{{item.title}}</text>
          </view>
          <view class="block-empty" wx:if="{{summaryData.checks.length === 0}}">暂无记录</view>
        </view>
      </view>

      <!-- 医生建议 -->
      <view class="section-block">
        <view class="block-title">医生建议</view>
        <view class="block-list">
          <view class="block-item" wx:for="{{summaryData.visits}}" wx:key="_id">
            <text class="item-date">{{item.date}}</text>
            <text class="item-text">{{item.doctorAdvice || item.title}}</text>
          </view>
          <view class="block-empty" wx:if="{{summaryData.visits.length === 0}}">暂无记录</view>
        </view>
      </view>

      <!-- 即将到期 -->
      <view class="section-block">
        <view class="block-title">即将到期事项</view>
        <view class="block-list">
          <view class="block-item" wx:for="{{summaryData.reminders}}" wx:key="_id">
            <text class="item-date">{{item.nextDate}}</text>
            <text class="item-text">{{item.title}}</text>
          </view>
          <view class="block-empty" wx:if="{{summaryData.reminders.length === 0}}">暂无记录</view>
        </view>
      </view>

      <!-- 免责声明 -->
      <view class="disclaimer">
        <text>本摘要仅用于病程整理，不作为医疗诊断依据</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="summary-actions">
      <button class="btn-primary" bindtap="onGenerateImage" loading="{{generatingImage}}">生成长图</button>
      <button class="btn-share" open-type="share">分享给医生</button>
    </view>
  </block>
</view>
