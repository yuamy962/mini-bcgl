.trend-container {
  padding-bottom: 40rpx;
}

.disclaimer-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--warning-bg);
  padding: 16rpx 30rpx;
  margin-bottom: 20rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: var(--warning);
  flex: 1;
  line-height: 1.4;
}

.disclaimer-btn {
  font-size: 24rpx;
  color: var(--primary);
  margin-left: 20rpx;
  flex-shrink: 0;
}

.range-tabs {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.range-tab {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 10rpx 30rpx;
  margin: 0 8rpx;
  border-radius: 32rpx;
  background: var(--white);
}

.range-tab.active {
  background: var(--primary);
  color: var(--white);
}

.chart-card {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.chart-empty {
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.risk-bar {
  margin: 0 30rpx 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.risk-bar.high {
  background: var(--danger-bg);
}

.risk-bar.medium {
  background: var(--warning-bg);
}

.risk-text {
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.5;
}

.record-list {
  padding: 0 30rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 28rpx;
  color: var(--text-secondary);
  width: 200rpx;
}

.record-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  flex: 1;
  text-align: center;
}

.record-hospital {
  font-size: 24rpx;
  color: var(--text-tertiary);
  width: 200rpx;
  text-align: right;
}
