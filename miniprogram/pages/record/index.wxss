.record-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 32rpx;
  box-sizing: border-box;
}

.record-sheet {
  background: var(--white);
  border-radius: 32rpx 32rpx 0 0;
  padding: 44rpx 32rpx;
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
  margin-top: 20vh;
  min-height: 80vh;
}

.record-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  text-align: center;
  margin-bottom: 44rpx;
}

.record-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.record-type-item {
  width: 30%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.record-close {
  margin-top: 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--primary);
  background: var(--primary-light);
  border-radius: var(--radius-btn);
  padding: 24rpx 0;
  font-weight: 500;
}

.record-form-area {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.form-back {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 500;
}

.form-type-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.form-placeholder {
  width: 80rpx;
}
