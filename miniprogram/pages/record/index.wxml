<view class="record-page">
  <!-- 类型选择面板 -->
  <view class="record-sheet" wx:if="{{!currentType}}">
    <view class="record-title">选择记录类型</view>
    <view class="record-grid">
      <view class="record-type-item" wx:for="{{recordTypes}}" wx:key="key" data-type="{{item.key}}" bindtap="onSelectType">
        <view class="type-icon">{{item.icon}}</view>
        <text class="type-label">{{item.label}}</text>
      </view>
    </view>
    <view class="record-close" bindtap="onClose">取消</view>
  </view>

  <!-- 表单区域 -->
  <view class="record-form-area" wx:if="{{currentType}}">
    <view class="form-header">
      <text class="form-back" bindtap="onBackToType">← 返回</text>
      <text class="form-type-title">{{currentTypeLabel}}</text>
      <text class="form-placeholder"></text>
    </view>

    <record-form-psa wx:if="{{currentType === 'psa'}}" bindsubmit="onFormSubmit" />
    <record-form-check wx:if="{{currentType === 'check'}}" bindsubmit="onFormSubmit" />
    <record-form-injection wx:if="{{currentType === 'injection'}}" bindsubmit="onFormSubmit" />
    <record-form-medicine wx:if="{{currentType === 'medicine'}}" bindsubmit="onFormSubmit" />
    <record-form-visit wx:if="{{currentType === 'visit'}}" bindsubmit="onFormSubmit" />
    <record-form-note wx:if="{{currentType === 'note'}}" bindsubmit="onFormSubmit" />
  </view>
</view>
