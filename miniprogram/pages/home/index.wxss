.home-container {
  padding-bottom: 140rpx;
}

.patient-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--white);
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
}

.patient-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-right: 16rpx;
}

.patient-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  font-weight: 500;
}

.patient-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.patient-status.status-observe { color: var(--success); background: var(--success-bg); }
.patient-status.status-treat { color: var(--primary); background: var(--primary-light); }
.patient-status.status-recover { color: var(--warning); background: var(--warning-bg); }

.summary-wrap {
  position: relative;
}

.summary-more {
  text-align: right;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.more-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.quick-actions {
  display: flex;
  justify-content: space-between;
  background: var(--white);
  border-radius: var(--radius);
  padding: 36rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.float-add-btn {
  position: fixed;
  bottom: 180rpx;
  right: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: var(--primary);
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-float);
  z-index: 100;
}

.add-icon {
  color: var(--white);
  font-size: 52rpx;
  font-weight: 300;
  line-height: 96rpx;
}
