.family-container {
  padding-bottom: 40rpx;
}

.member-card {
  margin-bottom: 20rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 500;
}

.member-role {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
  padding: 20rpx 0;
}

.operation-list {
  padding: 0 30rpx;
}

.operation-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.operation-item:last-child {
  border-bottom: none;
}

.op-text {
  font-size: 28rpx;
  color: var(--text-main);
  flex: 1;
  word-break: break-all;
  margin-right: 20rpx;
}

.op-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.btn-delete {
  background: var(--danger-bg);
  color: var(--danger);
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  margin-top: 20rpx;
}

.btn-delete::after {
  border: none;
}

.share-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.share-tip-panel {
  background: var(--white);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.share-tip-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
  color: var(--text-main);
}

.share-tip-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.share-tip-close {
  text-align: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 20rpx 0;
  margin-top: 10rpx;
}
