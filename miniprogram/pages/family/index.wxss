.family-container {
  padding-bottom: 40rpx;
}

.member-card {
  margin-bottom: 24rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 600;
}

.member-role {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.member-role.role-editable {
  color: var(--primary);
  background: var(--primary-light);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
  margin-top: 8rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
  padding: 24rpx 0;
}

.operation-list {
  padding: 0 32rpx;
}

.operation-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.operation-item:last-child {
  border-bottom: none;
}

.op-text {
  font-size: 28rpx;
  color: var(--text-main);
  flex: 1;
  word-break: break-all;
  margin-right: 20rpx;
}

.op-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.family-container .btn-primary,
.family-container .btn-delete {
  margin-left: 0;
  margin-right: 0;
  width: 100%;
}

.btn-delete {
  background: var(--danger-bg);
  color: var(--danger);
  border-radius: var(--radius-btn);
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  margin-top: 20rpx;
  font-weight: 500;
}

.btn-delete::after {
  border: none;
}

.share-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 200;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.share-tip-panel {
  background: var(--white);
  border-radius: 32rpx 32rpx 0 0;
  padding: 44rpx 32rpx;
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
}

.share-tip-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 24rpx;
  color: var(--text-main);
}

.share-tip-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.share-tip-close {
  text-align: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 20rpx 0;
  margin-top: 10rpx;
}
