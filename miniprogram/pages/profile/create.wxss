@import "../../styles/form-cell.wxss";

.create-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 60rpx;
}

.create-header {
  padding: 72rpx 32rpx 48rpx;
  background: linear-gradient(180deg, var(--primary-light) 0%, var(--bg) 100%);
}

.create-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.create-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.create-form {
  padding: 24rpx 32rpx;
}
