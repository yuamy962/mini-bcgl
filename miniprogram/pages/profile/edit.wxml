<view class="container edit-page">
  <view class="edit-header">
    <view class="edit-title">编辑患者档案</view>
  </view>

  <view class="edit-form">
    <!-- 必填信息 -->
    <view class="form-card">
      <view class="form-cell">
        <text class="form-cell-label">患者姓名 <text class="required">*</text></text>
        <input class="form-cell-input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onNameInput" maxlength="20" />
      </view>

      <picker mode="date" bindchange="onBirthDateChange" value="{{form.birthDate}}" end="{{today}}">
        <view class="form-cell form-cell-arrow">
          <text class="form-cell-label">出生日期 <text class="required">*</text></text>
          <text class="form-cell-value {{form.birthDate ? '' : 'placeholder'}}">{{form.birthDate || '请选择日期'}}</text>
        </view>
      </picker>

      <picker bindchange="onGenderChange" value="{{genderOptions.indexOf(form.gender)}}" range="{{genderOptions}}">
        <view class="form-cell form-cell-arrow">
          <text class="form-cell-label">性别 <text class="required">*</text></text>
          <text class="form-cell-value">{{form.gender}}</text>
        </view>
      </picker>

      <picker bindchange="onCancerChange" value="{{cancerOptions.indexOf(form.cancerType)}}" range="{{cancerOptions}}">
        <view class="form-cell form-cell-arrow">
          <text class="form-cell-label">癌种 <text class="required">*</text></text>
          <text class="form-cell-value">{{form.cancerType}}</text>
        </view>
      </picker>

      <picker mode="date" bindchange="onDateChange" value="{{form.diagnosisDate}}" end="{{today}}">
        <view class="form-cell form-cell-arrow">
          <text class="form-cell-label">确诊时间 <text class="required">*</text></text>
          <text class="form-cell-value {{form.diagnosisDate ? '' : 'placeholder'}}">{{form.diagnosisDate || '请选择日期'}}</text>
        </view>
      </picker>
    </view>

    <!-- 治疗信息 -->
    <view class="form-card">
      <picker bindchange="onStatusChange" value="{{statusOptions.indexOf(form.treatmentStatus)}}" range="{{statusOptions}}">
        <view class="form-cell form-cell-arrow">
          <text class="form-cell-label">当前治疗状态</text>
          <text class="form-cell-value {{form.treatmentStatus ? '' : 'placeholder'}}">{{form.treatmentStatus || '请选择'}}</text>
        </view>
      </picker>

      <view class="form-cell">
        <text class="form-cell-label">当前医院</text>
        <input class="form-cell-input" placeholder="可选" value="{{form.hospital}}" bindinput="onHospitalInput" />
      </view>

      <view class="form-cell">
        <text class="form-cell-label">主治医生</text>
        <input class="form-cell-input" placeholder="可选" value="{{form.doctor}}" bindinput="onDoctorInput" />
      </view>
    </view>

    <button class="btn-primary" bindtap="onSubmit">保存修改</button>
  </view>
</view>
